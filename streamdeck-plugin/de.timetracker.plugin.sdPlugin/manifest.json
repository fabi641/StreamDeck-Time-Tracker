{
  "Author": "TimeTracker",
  "Category": "TimeTracker",
  "CategoryIcon": "images/category-icon",
  "CodePathWin": "plugin.html",
  "CodePath": "plugin.html",
  "Description": "Zeiterfassung fuer Projekte direkt vom Stream Deck.",
  "Icon": "images/plugin-icon",
  "Name": "TimeTracker",
  "OS": [
    { "Platform": "windows", "MinimumVersion": "10" },
    { "Platform": "mac",     "MinimumVersion": "10.15" }
  ],
  "Software": { "MinimumVersion": "6.0" },
  "SDKVersion": 2,
  "Version": "2.0.0",
  "UUID": "de.timetracker.plugin",
  "Actions": [
    {
      "Icon": "images/action-icon",
      "Name": "Arbeitstimer",
      "States": [
        { "Title": "Start" },
        { "Title": "Stop"  }
      ],
      "Tooltip": "Arbeitszeit starten oder stoppen",
      "UUID": "de.timetracker.worktimer"
    },
    {
      "Icon": "images/action-icon",
      "Name": "Projekt",
      "PropertyInspectorPath": "property_inspector/inspector.html",
      "States": [
        { "Title": "Projekt" },
        { "Title": "Aktiv"   }
      ],
      "Tooltip": "Projekt aktivieren (nur eines gleichzeitig aktiv)",
      "UUID": "de.timetracker.project"
    },
    {
      "Icon": "images/action-icon",
      "Name": "Tageszeit",
      "States": [
        { "Title": "00:00" }
      ],
      "Tooltip": "Heutige Gesamtarbeitszeit (nur Anzeige)",
      "UUID": "de.timetracker.daytotal"
    }
  ]
}
